# ==============================================================================
# SECRETS & CONFIGURATION
# ==============================================================================
# Copy this file to .env and fill in your values.
# DO NOT commit .env to Git.
#
# Canonical env var names are defined in: src/mesh/infrastructure/config/env.py

# --- TAILSCALE (Required for all providers) ---
# Generate API keys at: https://login.tailscale.com/admin/settings/keys
# Use an API key (prefix: tskey-api-...) for programmatic access,
# or a Reusable auth key (prefix: tskey-auth-...) for node auth.
TAILSCALE_KEY=tskey-auth-example-yyyyy

# TAILSCALE_TAILNET is your Tailscale account name.
# Find it at: https://login.tailscale.com/admin/settings/general
# Example: "user@gmail.com" or "example.com"
TAILSCALE_TAILNET=example.tailnet.com

# ==============================================================================
# CLOUD PROVIDER (choose one)
# ==============================================================================

# --- DigitalOcean ---
# DIGITALOCEAN_API_TOKEN=do_token_xxxxx
# DO_REGION=nyc3

# --- AWS ---
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=wJalr...
# AWS_REGION=us-east-1

# --- Google Cloud ---
# GOOGLE_CREDENTIALS=path/to/service-account.json
# GOOGLE_PROJECT=my-project-id
# GOOGLE_ZONE=us-central1-a

# --- Azure ---
# AZURE_CLIENT_ID=xxxxx
# AZURE_CLIENT_SECRET=xxxxx
# AZURE_SUBSCRIPTION_ID=xxxxx
# AZURE_TENANT_ID=xxxxx

# --- Linode ---
# LINODE_API_KEY=xxxxx

# --- Vultr ---
# VULTR_API_KEY=xxxxx

# --- UpCloud ---
# UPCLOUD_USERNAME=xxxxx
# UPCLOUD_PASSWORD=xxxxx

# --- Exoscale ---
# EXOSCALE_API_KEY=xxxxx
# EXOSCALE_API_SECRET=xxxxx

# --- Scaleway ---
# SCALEWAY_ACCESS_KEY=xxxxx
# SCALEWAY_SECRET_KEY=xxxxx

# --- OVHcloud ---
# OVH_APPLICATION_KEY=xxxxx
# OVH_APPLICATION_SECRET=xxxxx
# OVH_CONSUMER_KEY=xxxxx

# --- Equinix Metal ---
# EQUINIXMETAL_API_KEY=xxxxx
# EQUINIXMETAL_PROJECT_ID=xxxxx
