# ==============================================================================
# SECRETS & CONFIGURATION
# ==============================================================================
# Copy this file to .env and fill in your values.
# DO NOT commit .env to Git.

# --- TAILSCALE ---
# 1. API Key (Required for Remote Provisioning via Pulumi)
#    Generate at: https://login.tailscale.com/admin/settings/keys
TAILSCALE_API_KEY=tskey-api-example-xxxxx

# 2. Tailnet Name (Required for Pulumi)
#    Example: "user@gmail.com" or "example.com"
TAILSCALE_TAILNET=example.tailnet.com

# 3. Reusable Auth Key (Required for Local Vagrant Development)
#    Generate a Reusable key at: https://login.tailscale.com/admin/settings/keys
#    Tag it with: tag:dev
TAILSCALE_KEY=tskey-auth-example-yyyyy

# --- AWS (Required for Remote Provisioning) ---
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=wJalr...
AWS_REGION=us-east-1
